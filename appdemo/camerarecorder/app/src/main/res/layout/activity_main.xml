<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 摄像头预览区域 - 使用固定比例 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/black"
        android:fitsSystemWindows="false">

        <TextureView
            android:id="@+id/textureView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <!-- 状态显示 - 当前连接/识别状态 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未识别"
            android:layout_gravity="center_horizontal|top"
            android:layout_marginTop="56dp"
            android:padding="6dp"
            android:background="#33808080"
            android:textSize="14sp"
            android:textColor="@android:color/white" />

        <!-- 翻译结果展示 - 缩小版，置于相机预览下方区域 -->
        <TextView
            android:id="@+id/tvTranslation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="100dp"
            android:text=""
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:shadowColor="#FF000000"
            android:shadowRadius="6"
            android:shadowDx="2"
            android:shadowDy="2"
            android:background="#AA000000"
            android:padding="10dp"
            android:maxWidth="280dp"
            android:visibility="gone"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center" />

        <!-- 调试浮层 - 显示在相机预览左上角，默认隐藏，长按状态栏切换 -->
        <TextView
            android:id="@+id/tvDebugOverlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginTop="100dp"
            android:layout_marginStart="8dp"
            android:padding="8dp"
            android:background="#CC000000"
            android:textColor="#00FF00"
            android:textSize="11sp"
            android:typeface="monospace"
            android:lineSpacingExtra="2dp"
            android:visibility="gone"
            android:text="调试面板加载中..." />

        <!-- 控制按钮区域 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:padding="16dp">

            <!-- 麦克风按钮 - 位于左面1/5处 -->
            <ImageButton
                android:id="@+id/btnMicrophone"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:padding="16dp"
                android:background="@drawable/circular_button_background_transparent"
                android:src="@drawable/ic_speaker"
                android:contentDescription="喇叭按钮"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/bottom_guideline"
                app:layout_constraintHorizontal_bias="0.15" />

            <!-- 录制按钮 - 缩小至0.5倍 -->
            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:padding="8dp"
                android:background="@drawable/circular_record_button_background"
                android:src="@drawable/ic_record_inactive_large"
                android:contentDescription="录制按钮"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/bottom_guideline" />

            <!-- 翻转摄像头按钮 - 位于右面1/5处 -->
            <ImageButton
                android:id="@+id/btnSwitch"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:padding="16dp"
                android:background="@drawable/circular_button_background_transparent"
                android:src="@drawable/ic_switch_camera"
                android:contentDescription="切换摄像头按钮"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/bottom_guideline"
                app:layout_constraintHorizontal_bias="0.85" />

            <!-- 历史记录按钮 - 位于右面 -->
            <ImageButton
                android:id="@+id/btnHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="10dp"
                android:background="@drawable/circular_button_background_transparent"
                android:src="@drawable/ic_history"
                android:contentDescription="翻译记录"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/btnRecord"
                app:layout_constraintHorizontal_bias="0.5"
                android:layout_marginBottom="8dp" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/bottom_guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_end="15dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>

</LinearLayout>
